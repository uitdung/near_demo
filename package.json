{
    "name": "near-demo",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "NEAR Protocol Demo",
    "scripts": {
        "setup": "npm install && cd backend && npm install",
        "build:contract": "node scripts/build-contract.js",
        "deploy:contract": "node scripts/deploy-contract.js",
        "start": "docker compose up --build",
        "start:detached": "docker compose up --build -d",
        "stop": "docker compose down",
        "logs": "docker compose logs -f",
        "rebuild": "docker compose down && docker compose up --build",
        "reset": "docker compose down -v"
    },
    "dependencies": {
        "near-api-js": "^4.0.0",
        "dotenv": "^16.3.1"
    }
}
