# Environment Variables
# Copy this file to .env and fill in your values

# NEAR Configuration
NEAR_NETWORK=testnet
NEAR_NODE_URL=https://rpc.testnet.near.org
NEAR_WALLET_URL=https://testnet.mynearwallet.com
NEAR_HELPER_URL=https://helper.testnet.near.org

# Contract Account ID (where your contract is deployed)
NEAR_CONTRACT_ID=your-contract.testnet

# Account for signing transactions (needs to have NEAR for gas)
# Create this account at https://testnet.mynearwallet.com
NEAR_MASTER_ACCOUNT=your-account.testnet

# Master account private key
# Get this from your wallet (can be found in account settings)
NEAR_MASTER_PRIVATE_KEY=ed25519:your-private-key-here

# Server Configuration
PORT=3000
