# Docker Environment Variables
# Copy this file to .env and fill in your values

# NEAR Contract ID (e.g., kvstore.your-account.testnet)
NEAR_CONTRACT_ID=your-contract.testnet

# NEAR Master Account (for signing transactions)
NEAR_MASTER_ACCOUNT=your-account.testnet

# NEAR Master Private Key (from wallet export)
NEAR_MASTER_PRIVATE_KEY=ed25519:your-private-key-here
